# ── Supabase（云同步必填，不填则纯 localStorage 模式）──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── TMDB（电影推荐，选填）──
# 免费注册：https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=

# ── 以下为 Supabase Edge Function Secrets，通过 CLI 设置，不放在此文件 ──
# supabase secrets set IGDB_CLIENT_ID=xxx
# supabase secrets set IGDB_CLIENT_SECRET=xxx
# supabase secrets set BANGUMI_TOKEN=xxx
#
# IGDB（游戏搜索，选填）— 注册：https://dev.twitch.tv/console
# BANGUMI（动漫搜索增强，选填）— 获取：https://bgm.tv 设置 → 个人令牌
