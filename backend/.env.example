# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM Provider: "claude" | "openai" | "deepseek" | "kimi" | "minimax"
LLM_PROVIDER=claude

# API Keys (set the ones you need)
CLAUDE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Embedding Provider: "openai" | "minimax"
EMBEDDING_PROVIDER=minimax

# External APIs
TMDB_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173
